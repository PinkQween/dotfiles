# Ignore everything by default; allow tracked dotfiles below.
*
!.gitignore
!.config/
!.config/hypr/
!.config/hypr/**
!.config/rofi/
!.config/rofi/**
!.config/waybar/
!.config/waybar/**
!.config/nvim/
!.config/nvim/**
!.config/kitty/
!.config/kitty/**
!.config/dunst/
!.config/dunst/**
!.config/btop/
!.config/btop/**

# Common local noise
*.log
*.tmp
*.swp
*.swo
